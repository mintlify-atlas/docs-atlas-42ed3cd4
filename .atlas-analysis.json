  "keyFeatures": [
    "Incremental parsing - efficiently update syntax trees as source code changes",
    "Language-agnostic - parse any programming language with custom grammars",
    "Error recovery - provide useful results even with syntax errors",
    "Query system - pattern matching for code analysis and transformation",
    "Multiple language bindings - C, Rust, JavaScript, Python, and more",
    "CLI tooling - develop, test, and debug parsers from the command line",
    "Syntax highlighting - generate highlighting themes from queries",
    "Code navigation - extract tags and symbols for IDE features"
  ],
  "publicApiSurface": [
    "Parser - main parsing interface",
    "Tree - syntax tree representation",
    "Node - individual nodes in the syntax tree",
    "Query - pattern matching queries",
    "Language - grammar/parser definitions",
    "InputEdit - incremental editing operations",
    "TreeCursor - efficient tree traversal",
    "QueryCursor - query execution and iteration",
    "tree-sitter CLI - command-line interface",
    "ts_parser_* - C API functions",
    "tree-sitter-generate - parser generator",
    "tree-sitter-highlight - syntax highlighting",
    "tree-sitter-tags - code navigation tags"
  ]
